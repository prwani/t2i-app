# Azure OpenAI / Foundry endpoint used with Azure AD via DefaultAzureCredential.
# Optional project endpoint for reference when using Azure Foundry portal/project APIs.
# FOUNDRY_PROJECT_ENDPOINT="https://<your-resource>.services.ai.azure.com/api/projects/<project-name>"
AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com"

# Azure AI Vision endpoint used with Azure AD via DefaultAzureCredential.
AZURE_VISION_ENDPOINT="https://<your-vision-resource>.cognitiveservices.azure.com"

# Deployment names. Replace with real deployment names when available.
MAI_IMAGE_2_DEPLOYMENT="MAI-Image-2"
MAI_IMAGE_2E_DEPLOYMENT="MAI-Image-2e"
MAI_IMAGE_2_5_FLASH_DEPLOYMENT="MAI-Image-2.5-Flash"
MAI_IMAGE_2_5_DEPLOYMENT="MAI-Image-2.5"
GPT_IMAGE_2_DEPLOYMENT="gpt-image-2"
SORA_2_DEPLOYMENT="sora-2"

# Evaluation deployments.
EVAL_DECOMPOSER_DEPLOYMENT="o4-mini"
EVAL_RUBRIC_DEPLOYMENT="o4-mini"
EVAL_JUDGE_DEPLOYMENT="gpt-5.4"

# Optional auth controls.
# AZURE_TENANT_ID="<tenant-id>"
# AZURE_OPENAI_SCOPE="https://ai.azure.com/.default"

# Optional request timeout for long-running generation/edit calls.
# AZURE_OPENAI_TIMEOUT_SECONDS=300
